-- Remember to edit /etc/site-config.jam when you update Python!
libtorrent-rasterbar = {
   url = "https://github.com/arvidn/libtorrent/releases/download/v2.0.12/libtorrent-rasterbar-2.0.12.tar.gz", 
   b3sum = "40217c0e2be187f4a80b380046ae7612fb3010ab987b3997e449b2f528115be2",
   build = _,
   post = [[ 
      BOOST_ROOT=/var/lib/boost_1_90_0
      b2="$BOOST_ROOT/tools/build/src/engine/b2"
      if ! test -x $b2; then cd "$BOOST_ROOT/tools/build" && ./bootstrap.sh; fi

      BOOST_ROOT="$BOOST_ROOT" \
      $b2 -j5 \
          variant=release \
          toolset=gcc \
          fpic=on \
          install \
          --prefix="$destdir/usr" \
          --libdir="$destdir/usr/lib64"

      PYTHON_SITE=`python3 -c 'from site import *;print(getsitepackages()[0])'`
      PYTHON_VERSION=`python3 -V | awk -F '[ .]' '{print $2 "." $3}'`
      cd bindings/python
      BOOST_ROOT=$BOOST_ROOT \
      $b2 -j5 \
          variant=release \
          python="$PYTHON_VERSION" \
          fpic=on \
          stage_module \
          install_module \
          python-install-path="$destdir/${PYTHON_SITE#*/}"
   ]]
};

