binutils-pass2 = {
   fs = "/var/cache/distfiles/binutils-2.46.0.tar.lz",
   build = "../configure",
   flags = {
      "--host=x86_64-unknown-linux-gnu",
      "--build=$(../config.guess)",
      "--prefix=/usr",
      "--enable-64-bit-bfd",
      "--enable-default-execstack=no",
      "--enable-default-hash-style=gnu",
      "--enable-deterministic-archives",
      "--enable-gprofng=no",
      "--enable-new-dtags",
      "--enable-relro",
      "--without-system-zlib",
   },
   prep = [[ sed '6031s/$add_dir//' -i ltmain.sh ]],
};

gcc-pass2 = {
   fs = "/var/cache/distfiles/gcc-16.1.0.tar.xz",
   build = "../configure",
   flags = {
      "--build=$(../config.guess)",
      "--host=x86_64-unknown-linux-gnu",
      "--target=x86_64-unknown-linux-gnu",
      "--prefix=/usr",
      "--libdir=/usr/libexec",
      "--with-build-sysroot=$destdir",
      "--disable-fixincludes",
      "--disable-gnu-indirect-function",
      "--disable-libatomic",
      "--disable-libgomp",
      "--disable-libquadmath",
      "--disable-libsanitizer",
      "--disable-libssp",
      "--disable-libstdcxx-pch",
      "--disable-libvtv",
      "--disable-multilib",
      "--disable-bootstrap",
      "--enable-checking=assert",
      "--enable-clocale=gnu",
      "--enable-__cxa_atexit",
      "--enable-default-pie",
      "--enable-default-ssp",
      "--enable-initfini-array",
      "--enable-languages=c,c++",
      "--enable-static",
      "--enable-threads=posix",
      "--enable-tls",
      "--with-linker-hash-style=gnu",
      "--with-system-zlib",
      "--without-included-gettext",
      "LDFLAGS_FOR_TARGET=-L$PWD/x86_64-unknown-linux-gnu/libgcc",
   },
   prep = [[
      mkdir gmp mpfr mpc isl
      tar -C gmp  --strip-components=1 -xf /var/cache/distfiles/gmp-6.3.0.tar.xz
      tar -C mpfr --strip-components=1 -xf /var/cache/distfiles/mpfr-4.2.2.tar.xz
      tar -C mpc  --strip-components=1 -xf /var/cache/distfiles/mpc-1.4.1.tar.xz
      tar -C isl  --strip-components=1 -xf /var/cache/distfiles/isl-0.27.tar.xz
      sed -i '330i #include <stdbool.h>' gcc/config/i386/i386.h
      sed -i '/thread_header =/s/@.*@/gthr-posix.h/' \
        {libgcc,libstdc++-v3/include}/Makefile.in
   ]]
};
