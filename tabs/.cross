binutils-pass1 = {
   fs = "/var/cache/distfiles/binutils-2.46.0.tar.lz",
   build = "../configure", 
   flags = {
      "--target=x86_64-unknown-linux-gnu",
      "--prefix=/tools",
      "--with-sysroot=$destdir",
      "--disable-nls",
      "--disable-werror",
      "--enable-default-execstack=no",
      "--enable-default-hash-style=gnu",
      "--enable-deterministic-archives",
      "--enable-gprofng=no",
      "--enable-new-dtags",
      "--enable-relro",
      "--without-system-zlib",
   }
};

gcc-pass1 = {
   fs = "/var/cache/distfiles/gcc-16.1.0.tar.xz",
   build = "../configure",
   flags = {
      "--target=x86_64-unknown-linux-gnu",
      "--prefix=/tools",
      "--with-glibc-version=2.43",
      "--with-newlib=yes",
      "--without-headers",
      "--with-sysroot=$destdir",
      "--disable-fixincludes",
      "--disable-gnu-indirect-function",
      "--disable-libatomic",
      "--disable-libgomp",
      "--disable-libquadmath",
      "--disable-libsanitizer",
      "--disable-libssp",
      "--disable-libstdcxx",
      "--disable-libvtv",
      "--disable-nls",
      "--disable-shared",
      "--disable-werror",
      "--disable-multilib",
      "--disable-bootstrap",
      "--enable-checking=assert",
      "--enable-clocale=gnu",
      "--enable-__cxa_atexit",
      "--enable-default-pie",
      "--enable-default-ssp",
      "--enable-initfini-array",
      "--enable-languages=c,c++",
      "--enable-threads=single",
      "--with-linker-hash-style=gnu",
      "--without-system-zlib",
      "--without-included-gettext",
   },
   prep = [[
      mkdir gmp mpfr mpc isl
      tar -C gmp  --strip-components=1 -xf /var/cache/distfiles/gmp-6.3.0.tar.xz
      tar -C mpfr --strip-components=1 -xf /var/cache/distfiles/mpfr-4.2.2.tar.xz
      tar -C mpc  --strip-components=1 -xf /var/cache/distfiles/mpc-1.4.1.tar.xz
      tar -C isl  --strip-components=1 -xf /var/cache/distfiles/isl-0.27.tar.xz
   ]],
   post = [[
      cat ../gcc/{limitx,glimits,limity}.h > _
      mv _ $(x86_64-unknown-linux-gnu-gcc -print-file-name=include/limits.h)
   ]]
};

glibc = {
   fs = "/var/cache/distfiles/glibc-2.43.tar.xz",
   build = "../configure",
   flags = {
      "--prefix=/usr",
      "--host=x86_64-unknown-linux-gnu",
      "--build=$(../scripts/config.guess)",
      "--enable-kernel=$(uname -r | cut -d . -f 1,2)",
      "--enable-bind-now",
      "--enable-stack-protector=strong",
      "--exec-prefix=/",
      "--disable-nscd",
      "--with-headers=$destdir/usr/include",
      "PYTHON_PROG=/opt/python3.13/bin/python3.13",
   },
   prep = [[
      $patch < /var/db/repos/okpkg/patches/glibc.diff
      printf "%s\n" rootsbindir=/bin >> configparms
      printf "%s\n" sbindir=/bin     >> configparms
      printf "%s\n" slibdir=/lib64   >> configparms
      printf "%s\n" rtlddir=/lib64   >> configparms
      printf "%s\n" auditdir=/lib64  >> configparms
      sed -i 's:^lib=.*audit:lib='\''/lib64:' ./elf/sotruss.sh
   ]]
};

libxcrypt = {
   fs = "/var/cache/distfiles/libxcrypt-4.5.2.tar.xz", 
   build = "./configure",
   flags = {
      "--prefix=/usr",
      "--host=x86_64-unknown-linux-gnu",
      "--build=$(build-aux/m4-autogen/config.guess)",
      "--enable-hashes=strong,glibc",
      "--enable-obsolete-api=no",
      "--disable-failure-tokens",
      "PERL=/opt/perl/bin/perl",
   }
};

libstdcxx = {
   fs = "/var/cache/distfiles/gcc-16.1.0.tar.xz",
   build = "../libstdc++-v3/configure",
   flags = {
      "--prefix=/usr",
      "--host=x86_64-unknown-linux-gnu",
      "--build=$(../config.guess)",
      "--with-gxx-include-dir=/tools/x86_64-unknown-linux-gnu/include/c++/16.1.0",
      "--disable-libstdcxx-pch",
      "--disable-multilib",
      "--enable-clocale=gnu",
      "--enable-tls",
   },
   prep = [[
      mkdir gmp mpfr mpc isl
      tar -C gmp  --strip-components=1 -xf /var/cache/distfiles/gmp-6.3.0.tar.xz
      tar -C mpfr --strip-components=1 -xf /var/cache/distfiles/mpfr-4.2.2.tar.xz
      tar -C mpc  --strip-components=1 -xf /var/cache/distfiles/mpc-1.4.1.tar.xz
      tar -C isl  --strip-components=1 -xf /var/cache/distfiles/isl-0.27.tar.xz
   ]],
};

m4 = {
   fs = "/var/cache/distfiles/m4-1.4.21.tar.xz", 
   build = "./configure",
   flags = {
      "--prefix=/usr",
      "--host=x86_64-unknown-linux-gnu",
      "--build=$(build-aux/config.guess)",
   }
};

ncurses = {
   fs = "/var/cache/distfiles/ncurses-6.6.tar.gz", 
   build = "./configure",
   flags = {
      "--prefix=/usr",
      "--host=x86_64-unknown-linux-gnu",
      "--build=$(./config.guess)",
      "--disable-root-access",
      "--disable-root-environ",
      "--disable-rpath-hack",
      "--disable-setuid-environ",
      "--disable-stripping",
      "--enable-hard-tabs",
      "--enable-pc-files",
      "--enable-widec",
      "--with-cxx-shared",
      "--with-manpage-format=normal",
      "--with-ospeed=unsigned",
      "--without-ada",
      "--without-debug",
      "--without-normal",
      "--without-tests",
      "--with-pkg-config-libdir=/lib64/pkgconfig",
      "--with-shared",
      "--with-termlib=tinfo",
      "--with-xterm-kbs=DEL",
      "ac_cv_path_TIC=$(realpath ./build/progs/tic)",
   },
   prep = [[
      mkdir build && cd build
      sed -i 's/mawk//' "../configure"
      sh ../configure
      make -C include
      make -C progs tic
   ]],
   post = [[
      cd "$destdir/usr/include"
      sed -i 's/^#if.*XOPEN.*$/#if 1/' curses.h
      cd "$destdir/lib64"
      rm -fr libncursesw.so ../usr/lib
      printf "INPUT(libncursesw.so.6 -ltinfo)\n" >> libncursesw.so
      ln -sf libform{w,}.so
      ln -sf libmenu{w,}.so
      ln -sf libncurses{w,}.so
      ln -sf libpanel{w,}.so
      cd "$destdir/lib64/pkgconfig"
      ln -sf form{w,}.pc
      ln -sf menu{w,}.pc
      ln -sf ncurses{w,}.pc
      ln -sf panel{w,}.pc
   ]]
};

bash = {
   fs = "/var/cache/distfiles/bash-5.3.tar.gz", 
   build = "./configure",
   flags = {
      "--prefix=/usr",
      "--host=x86_64-unknown-linux-gnu",
