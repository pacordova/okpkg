perl = {
   url = "https://www.cpan.org/src/5.0/perl-5.42.2.tar.xz",
   b3sum = "d8a9988b0fd5305204c74ac3cca7a19e47625ca65ad10723dfff129abaa4981a",
   build = "./configure.gnu",
   flags= {
      "-Dprefix=/opt/perl",
      "-Duseshrplib",
      "-Dusethreads",
      "-Dman1dir=/opt/perl/man/man1",
      "-Dman3dir=/opt/perl/man/man3",
   },
   post = [[
      find $destdir -name \*.pod       -exec rm -f {} +
      find $destdir -name .packlist    -exec rm -f {} +
      find $destdir -name README\*     -exec rm -f {} +
      find $destdir -name TODO\*       -exec rm -f {} +
      find $destdir -name Change\*     -exec rm -f {} +
      find $destdir -name \*.bs        -exec rm -f {} +
      find $destdir -name \*.0 -type f -exec rm -f {} +
      find $destdir/opt/perl/lib  -type f -exec chmod 644 {} +
   ]]
};

