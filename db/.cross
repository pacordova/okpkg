
binutils-pass1 = {
   url = _db_lookup("binutils")["url"],
   build = "../configure", 
   flags = {
      "--prefix=/tools",
      "--with-sysroot=$destdir",
      "--target=x86_64-unknown-linux-gnu",
      "--enable-deterministic-archives",
      "--enable-new-dtags",
      "--enable-{gprofng=no,nls=no,werror=no}",
      "--enable-default-{execstack=no,hash-style=gnu}",
      "CONFIG_SITE=",
   }
};

gcc-pass1 = {
   url = _db_lookup("gcc14")["url"],
   build = "../configure",
   flags = {
      "--prefix=/tools",
      "--target=x86_64-unknown-linux-gnu",
      "--with-glibc-version=2.43",
      "--with-sysroot=$destdir",
      "--with-newlib",
      "--without-headers",
      "--disable-libstdcxx",
      "--disable-{shared,threads}",
      "--enable-default-{pie,ssp}",
      "--disable-{nls,multilib}",
      "--disable-lib{atomic,gomp,quadmath,sanitizer,ssp,vtv}",
      "--enable-languages=c,c++",
      "--enable-link-serialization=1",
      "--enable-{__cxa_atexit,initfini-array}",
      "--disable-{bootstrap,fixincludes}",
      "--{enable-clocale,with-linker-hash-style}=gnu",
      "CONFIG_SITE=",
   },
   post = [[
      cat ../gcc/{limitx,glimits,limity}.h > _
      mv _ $(x86_64-unknown-linux-gnu-gcc -print-file-name=include)/limits.h
   ]]
};

glibc = {
   url = _db_lookup("glibc")["url"],
   build = "../configure",
   flags = {
      "--prefix=/usr",
      "--disable-nscd",
      "--enable-kernel=$(uname -r | cut -d . -f 1,2)",
      "--with-headers=$destdir/usr/include",
      "--host=x86_64-unknown-linux-gnu",
      "--build=$(../scripts/config.guess)",
      "libc_cv_slibdir=/lib64",
      "libc_cv_rtlddir=/lib64",
      "libc_cv_rootsbindir=/bin",
   }
};

gcc-libstdc++ = {
   url = _db_lookup("gcc14")["url"],
   build = "../libstdc++-v3/configure",
   flags = {
      "--prefix=/usr",
      "--disable-multilib",
      "--disable-nls",
      "--disable-libstdcxx-pch",
      "--with-gxx-include-dir=/tools/x86_64-unknown-linux-gnu/include/c++/14.3.0",
      "--enable-link-serialization=1",
      "--enable-{__cxa_atexit,initfini-array}",
      "--{enable-clocale,with-linker-hash-style}=gnu",
      "--host=x86_64-unknown-linux-gnu",
      "--build=$(../config.guess)",
   }
};

libxcrypt = {
   url = _db_lookup("libxcrypt")["url"],
   build = "./configure",
   flags = {
      "--prefix=/usr",
      "--disable-failure-tokens",
      "--enable-hashes=strong,glibc",
      "--enable-obsolete-api=no",
      "--host=x86_64-unknown-linux-gnu",
      "--build=$(build-aux/m4-autogen/config.guess)",
   }
};

m4 = {
   url = _db_lookup("m4")["url"],
   build = "./configure",
   flags = {
      "--prefix=/usr",
      "--host=x86_64-unknown-linux-gnu",
      "--build=$(build-aux/config.guess)",
   }
};

ncurses = {
   url = _db_lookup("ncurses")["url"],
   build = "./configure",
   flags = {
      "--prefix=/usr",
      "--with-manpage-format=normal",
      "--with-shared",
      "--enable-widec",
      "--disable-setuid-environ",
      "--disable-stripping",
      "--with-cxx-{binding=no,shared=yes}",
      "--with-{termlib=tinfo,xterm-kbs=del}",
      "--without-{ada,debug,normal}",
      --"--with-versioned-syms",
      "--host=x86_64-unknown-linux-gnu",
      "--build=$(./config.guess)",
      "ac_cv_path_TIC=$(realpath ./build/progs/tic)",
   },
   prep = [[
      mkdir build && cd build
      sed -i 's/mawk//' "../configure"
      sh ../configure
      make -C include
      make -C progs tic
   ]],
   post = [[
      ln -sf libncursesw.so $destdir/lib64/libncurses.so
      sed -i 's/^#if.*XOPEN.*$/#if 1/' $destdir/usr/include/curses.h
      #rm -f $destdir/usr/lib/terminfo
   ]]
};

bash = {
   url = _db_lookup("bash")["url"],
   build = "./configure",
   flags = {
      "--prefix=/usr",
      "--host=x86_64-unknown-linux-gnu",
      "--build=$(sh support/config.guess)",
      "--without-bash-malloc",
   },
};

coreutils = {
   url = _db_lookup("coreutils")["url"],
   build = "./configure",
   flags = {
      "--prefix=/usr",
      "--host=x86_64-unknown-linux-gnu",
      "--build=$(build-aux/config.guess)",
      "--enable-install-program=hostname",
      "--without-openssl",
      "FORCE_UNSAFE_CONFIGURE=1"
   }
};

diffutils = {
   url = _db_lookup("diffutils")["url"],
   build = "./configure",
   flags = {
      "--prefix=/usr",
      "--host=x86_64-unknown-linux-gnu",
      "--build=$(build-aux/config.guess)",
      "gl_cv_func_strcasecmp_works=y"
   }
};

findutils = {
   url = _db_lookup("findutils")["url"],
   build = "./configure",
   flags = {
      "--prefix=/usr",
      "--host=x86_64-unknown-linux-gnu",
      "--build=$(build-aux/config.guess)",
   },
};

gawk = {
   url = _db_lookup("gawk")["url"],
   build = "./configure",
   flags = {
      "--prefix=/usr",
      "--host=x86_64-unknown-linux-gnu",
      "--build=$(build-aux/config.guess)",
   },
   prep = [[ sed -i 's/extras//' Makefile.in ]]
};

grep = {
   url = _db_lookup("grep")["url"],
   build = "./configure",
   flags = {
      "--prefix=/usr",
      "--host=x86_64-unknown-linux-gnu",
      "--build=$(build-aux/config.guess)",
   }
};

zlib = {
   url = _db_lookup("zlib")["url"],
   build = "make",
   prep = [[
      prefix=/usr \
      libdir=/lib64 \
      mandir=/usr/man \
      CC=x86_64-unknown-linux-gnu-gcc \
      AR=x86_64-unknown-linux-gnu-ar \
      RANLIB=x86_64-unknown-linux-gnu-ranlib \
      /bin/sh ./configure
   ]],
};

pigz = {
   url = _db_lookup("pigz")["url"],
   build = "make_noinstall",
   flags = { 
      "CC=x86_64-unknown-linux-gnu-gcc" 
   },
   post = [[ 
      mkdir -p $destdir/bin
      mkdir -p $destdir/usr/man/man1
      cp -f  pigz   $destdir/bin/pigz
      cp -f  unpigz $destdir/bin/unpigz
      cp -f  pigz.1 $destdir/usr/man/man1/pigz.1
   ]]
};

make = {
   url = _db_lookup("make")["url"],
   build = "./configure",
   flags = {
      "--prefix=/usr",
      "--host=x86_64-unknown-linux-gnu",
      "--build=$(build-aux/config.guess)",
      "--without-guile",
   },
};

patch = {
   url = _db_lookup("patch")["url"],
   build = "./configure",
   flags = {
      "--prefix=/usr",
      "--host=x86_64-unknown-linux-gnu",
      "--build=$(build-aux/config.guess)"
   }
};

sed = {
   url = _db_lookup("sed")["url"],
   build = "./configure",
   flags = {
      "--prefix=/usr",
      "--host=x86_64-unknown-linux-gnu",
      "--build=$(build-aux/config.guess)",
   }
};

tar = {
   url = _db_lookup("tar")["url"],
   build = "./configure",
   flags = {
      "--prefix=/usr",
      "--host=x86_64-unknown-linux-gnu",
      "--build=$(build-aux/config.guess)",
      "FORCE_UNSAFE_CONFIGURE=1",
   }
};

xz = {
   url = _db_lookup("xz")["url"],
   build = "./configure",
   flags = {
      "--prefix=/usr",
      "--host=x86_64-unknown-linux-gnu",
      "--build=$(build-aux/config.guess)",
   },
};

lua = {
   url = _db_lookup("lua")["url"],
   build = "make",
   flags = {
      "TO_LIB=liblua.so.5.5.0",
      "MYCFLAGS=-fpic",
      "INSTALL_TOP=$destdir",
      "INSTALL_BIN=$destdir/bin",
      "INSTALL_INC=$destdir/usr/include",
      "INSTALL_LIB=$destdir/lib64",
      "INSTALL_MAN=$destdir/usr/man/man1",
      "INSTALL_LMOD=$destdir/usr/share/lua/5.5",
      "INSTALL_CMOD=$destdir/lib64/lua/5.5",
      "CC=x86_64-unknown-linux-gnu-gcc",
      "AR='x86_64-unknown-linux-gnu-ar rcu'",
      "RANLIB=x86_64-unknown-linux-gnu-ranlib",
      "linux",
   },
   prep = [[ $patch < /usr/okpkg/patches/lua.diff ]],
   post = [[
      cd $destdir/lib64
      ln -sf liblua.so.5.5.0 liblua.so.5.5
      ln -sf liblua.so.5.5.0 liblua.so
      mkdir -p pkgconfig && cd pkgconfig
      >>lua.pc printf "Name: Lua\n"
      >>lua.pc printf "Description: An Extensible Extension Language\n"
      >>lua.pc printf "Version: 5.5.0\n"
      >>lua.pc printf "Requires:\n"
      >>lua.pc printf "Libs: -L/lib64 -llua -lm\n"
      >>lua.pc printf "Cflags: -I/usr/include\n"
   ]]
};

lzlib = {
   url = _db_lookup("lzlib")["url"],
   build = "./configure",
   flags = {
      "--prefix=/usr",
      "--libdir=/lib64",
      "--mandir=/usr/man",
      "CC=x86_64-unknown-linux-gnu-gcc",
      "AR=x86_64-unknown-linux-gnu-ar",
   }
};

plzip = {
   url = _db_lookup("plzip")["url"],
   build = "./configure",
   flags = {
      "--prefix=/usr",
      "--bindir=/",
      "--mandir=/usr/man",
      "CXX=x86_64-unknown-linux-gnu-g++",
   },
};

util-linux = {
   url = _db_lookup("util-linux")["url"],
   build = "./configure",
   flags = {
      "--prefix=/usr",
      "--host=x86_64-unknown-linux-gnu",
      "--build=$(config/config.guess)",
      "--disable-all-programs",
      "--enable-lib{blkid,fdisk,mount,smartcols,uuid}",
      "--without-{python,systemd}",
   }
};

libressl = {
   url = _db_lookup("libressl")["url"],
   build = "./configure",
   flags = {
      "--prefix=/usr",
      "--host=x86_64-unknown-linux-gnu",
      "--build=$(./config.guess)",
      "--with-openssldir=/etc/ssl",
   }
};

pkgconf = {
   url = _db_lookup("pkgconf")["url"],
   build = "./configure",
   flags = {
      "--prefix=/usr",
      "--host=x86_64-unknown-linux-gnu",
      "--build=$(./config.guess)",
   },
};

binutils-pass2 = {
   url = _db_lookup("binutils")["url"],
   build = "../configure",
   flags = {
      "--prefix=/usr",
      "--host=x86_64-unknown-linux-gnu",
      "--build=$(../config.guess)",
      "--enable-64-bit-bfd",
      "--enable-shared",
      "--enable-deterministic-archives",
      "--enable-new-dtags",
      "--enable-{gprofng=no,nls=no,werror=no}",
      "--enable-default-{execstack=no,hash-style=gnu}",
   },
   prep = [[ sed '6031s/$add_dir//' -i ltmain.sh ]],
};

gcc-pass2 = {
   url = _db_lookup("gcc14")["url"],
   build = "../configure",
   flags = {
      "--prefix=/usr",
      "--host=x86_64-unknown-linux-gnu",
      "--build=$(../config.guess)",
      "--target=x86_64-unknown-linux-gnu",
      "--with-build-sysroot=$destdir",
      "--enable-languages=c,c++",
      "--enable-{__cxa_atexit,initfini-array}",
      "--enable-default-{pie,ssp}",
      "--enable-link-serialization=1",
      "--{enable-clocale,with-linker-hash-style}=gnu",
      "--disable-{nls,multilib}",
      "--disable-lib{atomic,gomp,quadmath,sanitizer,ssp,vtv}",
      "--disable-{bootstrap,fixincludes}",
      "LDFLAGS_FOR_TARGET=-L$PWD/x86_64-unknown-linux-gnu/libgcc",
   },
   prep = [[
      sed -i '/thread_header =/s/@.*@/gthr-posix.h/' \
        {libgcc,libstdc++-v3/include}/Makefile.in
   ]]
};
