bzip2 = {
    sha256 = "ab5a03176ee106d3f0fa90e381da478ddae405918153cca248e682cd0c4a2269",
    url = "https://sourceware.org/pub/bzip2/bzip2-1.0.8.tar.gz",
    build = "make",
    flags = {
        "PREFIX=${DESTDIR}/usr"
    },
    pre_install = [[
        sed -i 's@\(ln -s -f \)$(PREFIX)/bin/@\1@' Makefile
        sed -i "s@(PREFIX)/man@(PREFIX)/share/man@g" Makefile
        sed -i "s@(PREFIX)/lib@(PREFIX)/lib64@g" Makefile
        make -f Makefile-libbz2_so
        make clean
    ]],
    post_install = [[
        cp -a libbz2.so.* ${DESTDIR}/usr/lib64
        ln -s libbz2.so.1.0.8 ${DESTDIR}/usr/lib64/libbz2.so
        cp bzip2-shared ${DESTDIR}/usr/bin/bzip2
        for i in ${DESTDIR}/usr/bin/{bzcat,bunzip2}
        do
            ln -sf bzip2 $i
        done
        rm -f ${DESTDIR}/usr/lib64/libbz2.a
    ]]
};

