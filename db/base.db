    url = "https://ftp.nluug.nl/pub/vim/unix/vim-9.0.tar.bz2",
    build = "./configure",
    flags = {
        "--disable-nls",
        "--with-features=tiny"
    },
    pre_install = [[
        hostname "myhost"
        echo '#define SYS_VIMRC_FILE "/etc/vimrc"' >> src/feature.h
    ]],
    post_install = [[
        ln -s vim ${DESTDIR}/usr/bin/vi
        for L in  ${DESTDIR}/usr/share/man/{,*/}man1/vim.1
        do
