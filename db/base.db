zlib = {
    sha256 = "38ef96b8dfe510d42707d9c781877914792541133e1870841463bfa73f883e32"
    url = "https://zlib.net/zlib-1.3.1.tar.xz",
    build = "./configure",
    flags = {
        "--libdir=/usr/lib64"
    },
    post_install = [[
        rm -f ${DESTDIR}/usr/lib64/libz.a
    ]]
};

pigz = { 
    sha256 = "eb872b4f0e1f0ebe59c9f7bd8c506c4204893ba6a8492de31df416f0d5170fd0", 
    url = "https://zlib.net/pigz/pigz-2.8.tar.gz", 
    build = _, 
    post_install = [[ 
        make
        mkdir -p ${DESTDIR}/usr/bin
        mkdir -p ${DESTDIR}/usr/share/man/man1
        cp pigz unpigz ${DESTDIR}/usr/bin
        ln -s pigz ${DESTDIR}/usr/bin/gzip 
        ln -s unpigz ${DESTDIR}/usr/bin/gunzip 
        cp pigz.1 ${DESTDIR}/usr/share/man/man1
        ln -s pigz.1 ${DESTDIR}/usr/share/man/man1/gzip.1
    ]] 
};

ncurses = {
    sha256 = "6931283d9ac87c5073f30b6290c4c75f21632bb4fc3603ac8100812bed248159",
    url = "https://invisible-island.net/archives/ncurses/ncurses-6.4.tar.gz",
    build = "./configure",
    flags = {
        "--libdir=/usr/lib64", 
        "--mandir=/usr/share/man",
        "--with-shared", 
        "--without-debug",
        "--without-normal",
        "--without-ada",
        "--with-cxx-shared",
        "--enable-pc-files", 
        "--enable-widec",
        "--with-pkg-config=/usr/lib64/pkgconfig"
    },
    post_install = [[
        for lib in ncurses form panel menu 
        do
            rm -f ${DESTDIR}/usr/lib64/lib${lib}.so
            echo "INPUT(-l${lib}w)" > ${DESTDIR}/usr/lib64/lib${lib}.so
            ln -sf ${lib}w.pc ${DESTDIR}/usr/lib64/pkgconfig/${lib}.pc
        done
        rm -f ${DESTDIR}/usr/lib64/libcursesw.so
        echo "INPUT(-lncursesw)" > ${DESTDIR}/usr/lib64/libcursesw.so
        ln -sf libncurses.so ${DESTDIR}/usr/lib64/libcurses.so
    ]]
};

