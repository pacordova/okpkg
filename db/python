python3 = {
   url = "https://www.python.org/ftp/python/3.14.0/Python-3.14.0.tar.xz",
   sha3 = "e11818475734b8b1f6ddd6999629498440b44de4f983a9db44fc318e62de2834",
   build = "./configure",
   flags = {
      "--enable-loadable-sqlite-extensions",
      "--with-dbmliborder=gdbm:ndbm",
      "--with-platlibdir=lib64",
      "--with-system-expat",
      "--with-tzpath=/usr/share/zoneinfo",
      "--without-{doc-strings,ensurepip}",
      "CFLAGS_NODIST=-fno-semantic-interposition",
      "LDFLAGS_NODIST=-fno-semantic-interposition",
   },
   post = [[
     #rm -fr "$destdir/usr/bin/pydoc"*
     #rm -fr "$destdir/usr/lib64/python"*/pydoc* 
      rm -fr "$destdir/usr/bin/idle"*
      rm -fr "$destdir/usr/lib64/python"*/idlelib
      rm -fr "$destdir/usr/lib64/python"*/turtle*
      rm -fr "$destdir/usr/lib64/python"*/config-*
      rm -fr "$destdir/usr/lib64/python"*/test
      rm -fr "$destdir/usr/lib64/python"*/*/test
      rm -fr "$destdir/usr/lib64/python"*/*/tests
   ]]
};

