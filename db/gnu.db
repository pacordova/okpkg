ncurses = {
    url = "https://invisible-island.net/archives/ncurses/current/ncurses-6.4-20240309.tgz",
    build = "./configure",
    flags = {
        "--libdir=/usr/lib64", 
        "--mandir=/usr/share/man",
        "--disable-root-access",
        "--disable-root-environ",
        "--disable-setuid-environ",
        "--enable-widec",
        "--enable-pc-files", 
        "--with-shared", 
        "--without-debug",
        "--without-normal",
        "--with-cxx-shared",
        "--with-pkg-config=/usr/bin/pkgconf",
        "--with-pkg-config-libdir=/usr/lib64/pkgconfig",
        "--enable-symlinks",
        "--with-termlib=tinfo",
        "--with-ticlib=tic",
        "--without-ada"
    },
    post = [[
        cd "$DESTDIR/usr/lib64"
        rm -f libform.so libpanel.so libmenu.so libcurses.so libcursesw.so \
            libncurses.so libncursesw.so libtermcap.so
        echo "INPUT(-lformw)" > libform.so
        echo "INPUT(-lpanelw)" > libpanel.so
        echo "INPUT(-lmenuw)" > libmenu.so
        echo "INPUT(-lncurses)"  > libcurses.so
        echo "INPUT(-lncursesw)" > libcursesw.so
        echo "INPUT(-lncursesw -ltinfo)" > libncurses.so
        echo "INPUT(libncursesw.so.6 -ltinfo)" > libncursesw.so
        echo "INPUT(-ltinfo)" > libtermcap.so
        ln -s ncursesw.pc pkgconfig/ncurses.pc
        ln -s formw.pc pkgconfig/form.pc
        ln -s panelw.pc pkgconfig/panel.pc
        ln -s menuw.pc pkgconfig/menu.pc
    ]]
};

octave = {
    url = "https://ftp.gnu.org/gnu/octave/octave-8.4.0.tar.gz",
