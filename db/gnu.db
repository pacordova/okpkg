autoconf = {
    url = "https://ftp.gnu.org/gnu/autoconf/autoconf-2.72.tar.xz",
    build = "./configure"
};

automake = {
    url = "https://ftp.gnu.org/gnu/automake/automake-1.16.5.tar.xz",
    build = "./configure"
};

bash = {
    url = "https://ftp.gnu.org/gnu/bash/bash-5.2.21.tar.gz",
    build = "./configure",
    flags = {
        "--libdir=/usr/lib64",
        "--mandir=/usr/share/man",
        "--disable-nls",
        "--with-curses",
        "--enable-readline",
        "--without-bash-malloc",
        "--with-installed-readline"
    },
    post = [[
        cd "$DESTDIR"
        ln -sf bash usr/bin/sh
        rm -f usr/bin/bashbug 
        rm -f usr/share/man/man1/bashbug.1
    ]]
};

binutils = {
    url = "https://ftp.gnu.org/gnu/binutils/binutils-2.42.tar.xz",
    build = "./configure",
    flags = {
        "--libdir=/usr/lib64",
        "--with-lib-path=/usr/lib64",
        "--enable-deterministic-archives",
        "--sysconfdir=/etc",
        "--enable-gold", 
        "--enable-lto",
        "--enable-ld=default",
        "--enable-plugins",
        "--enable-threads",
        "--disable-multilib",
        "--disable-werror",
        "--disable-gdb",
        "--disable-nls",
        "--disable-readline",
        "--disable-gprofng",
        "--with-system-zlib",
        "--enable-64-bit-bfd",
        "--enable-shared",
        "--enable-default-hash-style=gnu"
    },
    prepare = [[
        sed -i 's/tooldir=.*/tooldir=\/usr/g' configure
    ]],
    post = [[
        cd "$DESTDIR"
        rm -r usr/lib
        rm -f usr/lib64/libbfd.a
        rm -f usr/lib64/libctf.a
        rm -f usr/lib64/libctf-nobfd.a
        rm -f usr/lib64/libsframe.a
        rm -f usr/lib64/libopcodes.a
        rm -f usr/share/man/man1/gprofng.1
        rm -f usr/share/man/man1/gp-*.1
    ]]

};

bison = {
    url = "https://ftp.gnu.org/gnu/bison/bison-3.8.2.tar.xz",
    build = "./configure",
    flags = {
        "--libdir=/usr/lib64",
        "--datadir=/usr/share",
        "--disable-nls"
    }
};

coreutils = {
    url = "https://ftp.gnu.org/gnu/coreutils/coreutils-9.4.tar.xz",
    build = "./configure",
    flags = {
        "--libexecdir=/usr/lib64",
        "--sbindir=/usr/bin",
        "--disable-nls",
        "--enable-no-install-program=kill,uptime",
        "--without-openssl",
        "FORCE_UNSAFE_CONFIGURE=1"
    }
};

cpio = {
    url = "https://ftp.gnu.org/gnu/cpio/cpio-2.15.tar.bz2",
    build = "./configure",
    flags = {
        "--mandir=/usr/share/man",
        "--disable-nls"
    }
};

diffutils = {
    url = "https://ftp.gnu.org/gnu/diffutils/diffutils-3.10.tar.xz",
    build = "./configure",
    flags = {
        "--disable-nls"
    }
};

ed = {
    url = "https://ftp.gnu.org/gnu/ed/ed-1.20.1.tar.lz",
    build = "./configure",
    flags = {
        "--bindir=/usr/bin",
        "--mandir=/usr/share/man"
    }
};

findutils = {
    url = "https://ftp.gnu.org/gnu/findutils/findutils-4.9.0.tar.xz",
    build = "./configure",
    flags = {
        "--localstatedir=/var",
        "--disable-nls"
    },
    post = [[
        rm -fr "$DESTDIR"/usr/libexec 
        rm -fr "$DESTDIR"/usr/share/man/man5
        rm -f "$DESTDIR"/usr/bin/locate
        rm -f "$DESTDIR"/usr/bin/updatedb
        rm -f "$DESTDIR"/usr/share/man/man1/locate.1
        rm -f "$DESTDIR"/usr/share/man/man1/updatedb.1
    ]]
};

gawk = {
    url = "https://ftp.gnu.org/gnu/gawk/gawk-5.3.0.tar.xz",
    build = "./configure",
    flags = {
        "--libdir=/usr/lib64",
        "--libexecdir=/usr/lib64",
        "--sysconfdir=/etc",
        "--without-libsigsegv",
        "--disable-nls"
    }
};

gcc11 = {
    url = "https://ftp.gnu.org/gnu/gcc/gcc-11.4.0/gcc-11.4.0.tar.xz",
    build = "../configure",
    flags = {
        "--libdir=/usr/lib64",
        "--libexecdir=/usr/lib64",
        "--mandir=/usr/share/man",
        "--with-linker-hash-style=gnu",
        "--with-system-zlib",
        "--enable-languages=ada,c,c++,d",
        "--enable-threads=posix",
        "--enable-clocale=gnu",
        "--enable-gnu-unique-object",
        "--enable-__cxa_atexit",
        "--enable-default-pie",
        "--enable-default-ssp",
        "--enable-shared",
        "--enable-plugin",
        "--enable-bootstrap",
        "--disable-werror",
        "--disable-multilib",
        "--disable-nls",
        "--disable-libstdcxx-pch",
        "--disable-libssp",
        "LD=ld"
    },
    prepare = [[
        find /opt/gnat -name ld -exec mv -v {} {}.old \;
        find /opt/gnat -name as -exec mv -v {} {}.old \;
    ]],
    post = [[
        CHOST=$("$DESTDIR"/usr/bin/gcc -dumpmachine)
        pkgver=$("$DESTDIR"/usr/bin/gcc -dumpversion)
        find "$DESTDIR" -name libgtkpeer.a  -exec rm -f '{}' +
        find "$DESTDIR" -name libgjsmalsa.a -exec rm -f '{}' +
        find "$DESTDIR" -name libgij.a      -exec rm -f '{}' +
        ln -sr /usr/bin/cpp "$DESTDIR"/usr/lib64
        mkdir -p "$DESTDIR"/usr/lib64/bfd-plugins
        ln -sf ../../lib64/gcc/$CHOST/$pkgver/liblto_plugin.so \
            "$DESTDIR"/usr/lib64/bfd-plugins/
        mkdir -p "$DESTDIR"/usr/share/gdb/auto-load/usr/lib64
        mv "$DESTDIR"/usr/lib64/*gdb.py \
            "$DESTDIR"/usr/share/gdb/auto-load/usr/lib64
        ln -s gcc "$DESTDIR"/usr/bin/cc
        ln -s gcc "$DESTDIR"/usr/bin/c99
        cd "$DESTDIR"/usr/lib64/gcc/$CHOST/$pkgver
        strip -s cc1 cc1plus lto1 lto-wrapper collect2 g++-mapper-server
    ]]
};

gcc13 = {
    url = "https://ftp.gnu.org/gnu/gcc/gcc-13.2.0/gcc-13.2.0.tar.xz",
    build = "../configure",
    flags = {
        "--libdir=/usr/lib64",
        "--libexecdir=/usr/lib64",
        "--mandir=/usr/share/man",
        "--with-linker-hash-style=gnu",
        "--with-system-zlib",
        "--enable-languages=c,c++",
        "--enable-threads=posix",
        "--enable-clocale=gnu",
        "--enable-gnu-unique-object",
        "--enable-checking=release",
        "--enable-bootstrap",
        "--enable-__cxa_atexit",
        "--enable-default-pie",
        "--enable-default-ssp",
        "--enable-shared",
        "--enable-plugin",
        "--enable-lto",
        "--disable-werror",
        "--disable-fixincludes",
        "--disable-multilib",
        "--disable-nls",
        "--disable-libstdcxx-pch",
        "--disable-libssp",
        "LD=ld"
    },
    post = [[
        CHOST=$("$DESTDIR"/usr/bin/gcc -dumpmachine)
        pkgver=$("$DESTDIR"/usr/bin/gcc -dumpversion)
        find "$DESTDIR" -name libgtkpeer.a  -exec rm -f '{}' +
        find "$DESTDIR" -name libgjsmalsa.a -exec rm -f '{}' +
        find "$DESTDIR" -name libgij.a      -exec rm -f '{}' +
        ln -sr /usr/bin/cpp "$DESTDIR"/usr/lib64
        mkdir -p "$DESTDIR"/usr/lib64/bfd-plugins
        ln -sf ../../lib64/gcc/$CHOST/$pkgver/liblto_plugin.so \
            "$DESTDIR"/usr/lib64/bfd-plugins/
        mkdir -p "$DESTDIR"/usr/share/gdb/auto-load/usr/lib64
        mv "$DESTDIR"/usr/lib64/*gdb.py \
            "$DESTDIR"/usr/share/gdb/auto-load/usr/lib64
        ln -s gcc "$DESTDIR"/usr/bin/cc
        ln -s gcc "$DESTDIR"/usr/bin/c99
        cd "$DESTDIR"/usr/lib64/gcc/$CHOST/$pkgver
        strip -s cc1 cc1plus lto1 lto-wrapper collect2 g++-mapper-server
    ]]
};

gdb = {
    url = "https://ftp.gnu.org/gnu/gdb/gdb-14.1.tar.xz",
