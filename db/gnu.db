grub = {
    url = "https://ftp.gnu.org/gnu/grub/grub-2.12.tar.xz",
    build = "./configure",
    flags = {
        "--libdir=/usr/lib64",
        "--mandir=/usr/share/man",
        "--datarootdir=/usr/share",
        "--sbindir=/usr/bin",
        "--bindir=/usr/bin",
        "--sysconfdir=/etc",
        "--with-bootdir=/boot",
        "--with-grubdir=grub",
        "--enable-device-mapper",
        "--disable-efiemu",
        "--disable-werror",
        "--disable-nls",
        "--disable-silent-rules",
        "--disable-grub-mkfont",
        "--disable-grub-mount",
        "{C,CPP,CXX,LD}FLAGS="
    },
    prepare = [[
        echo depends bli part_gpt > grub-core/extra_deps.lst
    ]],
    post = [[
        cd "$DESTDIR"
        rm -f usr/lib64/grub/*/*.module
        rm -f usr/lib64/grub/*/*.image
        rm -f usr/lib64/grub/*/kernel.exec
        rm -f usr/lib64/grub/*/gdb_grub
