gnupg = {
    url = "https://gnupg.org/ftp/gcrypt/gnupg/gnupg-2.4.5.tar.bz2",
    build = "./configure",
    flags = {
        "--libexecdir=/usr/lib64/gnupg",
        "--enable-maintainer-mode",
        "--sbindir=/usr/bin",
        "--sysconfdir=/etc"
    }
};

gnupg1 = {
    url = "https://gnupg.org/ftp/gcrypt/gnupg/gnupg-1.4.23.tar.bz2",
    build = "./configure",
    flags = {
        "--sysconfdir=/etc",
        "--libexecdir=/usr/lib64",
        "--enable-noexecstack",
        "--disable-nls"
    },
    post = [[
        sed -i -e "s/$(date +'%Y-%m-%d')/$(date -d @$SOURCE_DATE_EPOCH +'%Y-%m-%d')/" \
            "$DESTDIR"/usr/share/man/man1/gpg.1 "$DESTDIR"/usr/share/man/man1/gpgv.1
    ]]
};
