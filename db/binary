zig-bin = {
   url = "https://ziglang.org/download/0.13.0/zig-linux-x86_64-0.13.0.tar.xz",
   sha3 = "60947fd18bcdd206b579ee510db6cdfd3f86d7ac6776ebe9045e13502c259e63",
   post = [[
      install -d $destdir/usr/{bin,lib64}
      install zig $destdir/usr/bin
      cp -rp lib $destdir/usr/lib64/zig
      ln -sf lib64 $destdir/usr/lib
   ]]
};

rust = {
   url = "https://static.rust-lang.org/dist/rust-1.89.0-x86_64-unknown-linux-gnu.tar.xz",
   sha3 = "c17bdd89089587e143461610ae91170e718fbe13aa4ad1a56eca5f807ce81ecd",
   build = _,
   post = [[ 
      install -d $destdir/usr
      ./install.sh --destdir=$destdir --prefix=/usr --libdir=$destdir/usr/lib64
      mv $destdir/usr/libexec/* $destdir/usr/lib64
      rmdir $destdir/usr/libexec
      rm -fr $destdir/usr/etc
      : > $destdir/.nostrip
   ]]
};

firefox = {
   url = "https://download-installer.cdn.mozilla.net/pub/firefox/releases/149.0/linux-x86_64/en-US/firefox-149.0.tar.xz",
   sha3 = "c35cbdc9c8a6eca0f8a4e821d6df51f3889524e0fb034e127888bf2126fe5502",
   build = _,
   post = [[
      mkdir -p "$destdir/usr/"{bin,lib64,share/applications}
      cp -f /var/cache/ok/dist/firefox.desktop $destdir/usr/share/applications
      cp -fr . $destdir/usr/lib64/firefox
      ln -sf /usr/lib64/firefox/firefox $destdir/usr/bin/firefox
      cd $destdir/usr/lib64/firefox
      for f in *.so; do ln -sf firefox/$f ..; done
   ]]
};

libreoffice = {
   url = "https://download.documentfoundation.org/libreoffice/stable/26.2.2/deb/x86_64/LibreOffice_26.2.2_Linux_x86-64_deb.tar.gz",
   sha3 = "b98e11657e0af8fa715b564f2cb28c707bdeea22d2dc9e31a36cd62de4ec3a3d",
   prep = [[
      mkdir -p "$destdir"
      rm -f DEBS/*{firebird,kde-integration,python-script-provider}*
      for f in DEBS/*; do 
        ar x "$f" data.tar.xz 
        gtar -C "$destdir" -xf data.tar.xz \
          --xform='s|usr/lib|usr/lib64|;s|opt|usr/lib64|;s|usr/local|usr|'
        rm -f data.tar.xz
      done
      sed -e 's/^Icon=libreoffice.*-/Icon=libreoffice-/' \
          -i "$destdir/usr/lib64/libreoffice"*/share/xdg/*.desktop
      ln -sf `basename "$destdir/usr/bin/"*` "$destdir/usr/bin/libreoffice"
   ]]
};

