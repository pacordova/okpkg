signal-desktop = {
   url = "https://updates.signal.org/desktop/apt/pool/s/signal-desktop/signal-desktop_8.5.0_amd64.deb",
   sha3 = "0ff99d9bdb66aba42048ffaf86db9b3cea7f1235c1b4ba95093b9e53e6b7f38b",
   build = _,
   post = [[
      ar x /var/cache/ok/dist/signal-desktop_8.5.0_amd64.deb data.tar.xz
      tar -xf data.tar.xz
      mkdir -p $destdir/usr/{lib64,bin}
      sed -i 's:/opt/Signal:/usr/bin:' ./usr/share/applications/signal-desktop.desktop
      install -d $destdir/usr/{bin,lib64/signal-desktop,share}
      cp -fr opt/Signal/* $destdir/usr/lib64/signal-desktop
      cp -fr usr/share/*  $destdir/usr/share
      ln -sf /usr/lib64/signal-desktop/signal-desktop $destdir/usr/bin/signal-desktop
   ]]
};

