vulkan-headers = {
   url = "https://github.com/KhronosGroup/Vulkan-Headers/archive/vulkan-sdk-1.4.341.0/Vulkan-Headers-vulkan-sdk-1.4.341.0.tar.gz",
   sha3 = "3c57b207e78c4d79348170c61f4c1dacf821a686299c8fed75c42063a1f8c40f",
   build = "cmake",
};

vulkan-loader = {
   url = "https://github.com/KhronosGroup/Vulkan-Loader/archive/vulkan-sdk-1.4.304.0/Vulkan-Loader-vulkan-sdk-1.4.304.0.tar.gz",
   sha3 = "4290273cbf288e9c85c1f95601de56e6fdc19a00b631772aa67c3853a634716d",
   build = "cmake",
   flags = {
      "-DBUILD_TESTS=OFF",
      "-DBUILD_WSI_{WAYLAND_SUPPORT=OFF,XCB_SUPPORT=ON,XLIB_SUPPORT=ON}",
      "-DVULKAN_HEADERS_INSTALL_DIR=/usr"
   }
};

nv-codec-headers = {
   url = "https://github.com/FFmpeg/nv-codec-headers/archive/n13.0.19.0/nv-codec-headers-n13.0.19.0.tar.gz",
   sha3 = "86219e738be1a39192977ae03b17262bffc649068f56fc95b0c210a34104bf9a",
   build = "make",
   flags = { "PREFIX=/usr", "LIBDIR=lib64" }
};

nvidia-vaapi-driver = {
   url = "https://github.com/elFarto/nvidia-vaapi-driver/archive/v0.0.12/nvidia-vaapi-driver-0.0.12.tar.gz",
   sha3 = "c28f79aefa8ea0f260ca6754e417a590a20d2001bdad502e3c0efe8ec157e20e",
   build = "meson",
};

libass = {
   url = "https://github.com/libass/libass/releases/download/0.17.4/libass-0.17.4.tar.xz",
   sha3 = "f347492db6281a1ea7feaa9cb3be953f32ecd9aad9307b87b925522efd4f209e",
   build = "./configure",
   flags = { "--enable-fontconfig" }
};

ffmpeg = {
   url = "https://ffmpeg.org/releases/ffmpeg-8.1.tar.xz",
   sha3 = "3bc7b3e99627f027378a9c3caa60c0cb39f367d5200848709514c698b684ec71",
   build = "./configure",
   flags = {
      "--libdir=/usr/lib64",
      "--enable-gpl",
      "--enable-version3",
      "--disable-static",
      "--enable-shared",
      "--disable-debug",
      "--enable-libass",
      "--enable-libdrm",
      "--enable-libmp3lame",
      "--enable-libopus",
      "--enable-libvorbis",
      "--enable-libvpx",
      "--enable-libx264",
      "--enable-libx265",
      "--x86asmexe=nasm",
      "--enable-nonfree",
      "--enable-libtls",
   },
   post = [[ rm -fr $destdir/usr/share/ffmpeg/examples ]]
};

libplacebo = {
   url = "https://code.videolan.org/videolan/libplacebo/-/archive/v7.360.1/libplacebo-v7.360.1.tar.bz2",
   sha3 = "b4c997f5a845197e654441d05552b796ef2761933be91a65d2e5c362ab1fd617",
   build = "meson",
   flags = { 
      "-Dvulkan=enabled",
      "-Dopengl=enabled",
      "-Dd3d11=disabled",
      "-Dglslang=disabled",
      "-Dlcms=enabled",
      "-Dxxhash=enabled",
      "-Ddemos=false",
      "-Dtests=false",
   }
};

uchardet = {
   url = "https://www.freedesktop.org/software/uchardet/releases/uchardet-0.0.8.tar.xz",
   sha3 = "a6b22fbf93ac19bc33d2f06bba03abdd36d53e58c3b575722de5d6f2d4219597",
   build = "cmake",
   flags = { "-DBUILD_STATIC=OFF" }
};

mpv = {
   url = "https://github.com/mpv-player/mpv/archive/v0.41.0/mpv-0.41.0.tar.gz",
   sha3 = "64b566216c94c7b2613a6833ce672d5ca4d1adeafa372cace6961bc6fff29a8d",
   build = "meson",
   flags = {
      "-Dlua=disabled",
      "-Dlibmpv=true",
      "-Dbuild-date=false",
      "-D{x11,alsa}=enabled",
      "-D{wayland,pipewire,pulse}=disabled",
      "-Dlibarchive=enabled",
      "-Dcaca=disabled",
      "-Ddrm=enabled",
   }
};
