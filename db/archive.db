pigz = {
    sha256 = "eb872b4f0e1f0ebe59c9f7bd8c506c4204893ba6a8492de31df416f0d5170fd0",
    url = "https://zlib.net/pigz/pigz-2.8.tar.gz",
    build = _,
    post_install = [[
        make
        mkdir -p ${DESTDIR}/usr/bin
        mkdir -p ${DESTDIR}/usr/share/man/man1
        cp pigz unpigz ${DESTDIR}/usr/bin
        ln -s pigz ${DESTDIR}/usr/bin/gzip
        ln -s unpigz ${DESTDIR}/usr/bin/gunzip
        cp pigz.1 ${DESTDIR}/usr/share/man/man1
        ln -s pigz.1 ${DESTDIR}/usr/share/man/man1/gzip.1
    ]]
};

neovim = {
    sha256 = _,
    url = "https://github.com/neovim/neovim/archive/refs/tags/stable.tar.gz",
    build = "cmake"
};

pam = {
    sha256 = _,
    url = "https://github.com/linux-pam/linux-pam/releases/download/v1.5.3/Linux-PAM-1.5.3.tar.xz",
    build = "./configure",
    flags = {
        "--libdir=/usr/lib64",
        "--sbindir=/usr/sbin",
        "--sysconfdir=/etc",
        "--disable-nls",
        "--libdir=/usr/lib64",
        "--enable-securedir=/usr/lib64/security"
    },
    post_install = [[
        chmod 4755 ${DESTDIR}/usr/sbin/unix_chkpwd
    ]]
};

gzip = {
    sha256 = "7454eb6935db17c6655576c2e1b0fabefd38b4d0936e0f87f48cd062ce91a057",
    url = "https://mirrors.kernel.org/gnu/gzip/gzip-1.13.tar.xz",
    build = "./configure"
};

sysklogd = {
    sha256 = "5166c185ae23c92e8b9feee66a6e3d0bc944bf673112f53e3ecf62e08ce7c201",
    url = "https://www.infodrom.org/projects/sysklogd/download/sysklogd-1.5.1.tar.gz",
    build = "make",
    flags = {
        "BINDIR=${DESTDIR}/usr/libexec",
        "MANDIR=${DESTDIR}/usr/share/man",
    },
    pre_install = [[
        sed -i '/Error loading kernel symbols/{n;n;d}' ksym_mod.c
        sed -i 's/union wait/int/' syslogd.c
        sed -i 's/syslogd.pid/syslog.pid/g' Makefile
        mkdir -p ${DESTDIR}/usr/share/man/man5 
        mkdir -p ${DESTDIR}/usr/share/man/man8 
        mkdir -p ${DESTDIR}/usr/libexec
    ]]
};

ell = {
    sha256 = _,
    url = "https://mirrors.edge.kernel.org/pub/linux/libs/ell/ell-0.57.tar.xz",
    build = "./configure",
    flags = {
        "--libdir=/usr/lib64"
    }
};

editline = {
    sha256 = _,
    url = "https://www.thrysoee.dk/editline/libedit-20221030-3.1.tar.gz",
    build = "./configure",
    flags = {
        "--libdir=/usr/lib64",
        "--enable-widec"
    },
    post_install = [[
        ln -sf libedit.a ${DESTDIR}/usr/lib64/libreadline.a
        ln -sf libedit.so ${DESTDIR}/usr/lib64/libreadline.so
        mkdir -p ${DESTDIR}/usr/include/readline
        touch ${DESTDIR}/usr/include/readline/history.h
        touch ${DESTDIR}/usr/include/readline/tilde.h
        ln -sf ../editline/readline.h ${DESTDIR}/usr/include/readline/readline.h
        ln -sf libedit.pc ${DESTDIR}/usr/lib64/pkgconfig/readline.pc
    ]]
};

