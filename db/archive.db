-- alternative shell
rc = {
    url = "https://github.com/pacordova/rc/archive/refs/heads/master.tar.gz",
    build = "make"
};

-- alternative sysklogd
sysklogd = {
    url = "https://www.infodrom.org/projects/sysklogd/download/sysklogd-1.5.1.tar.gz",
    build = "make",
    flags = {
        "BINDIR=${DESTDIR}/usr/libexec",
        "MANDIR=${DESTDIR}/usr/share/man",
    },
    prepare = [[
        sed -i '/Error loading kernel symbols/{n;n;d}' ksym_mod.c
        sed -i 's/union wait/int/' syslogd.c
        sed -i 's/syslogd.pid/syslog.pid/g' Makefile
        mkdir -p ${DESTDIR}/usr/share/man/man5 
        mkdir -p ${DESTDIR}/usr/share/man/man8 
        mkdir -p ${DESTDIR}/usr/libexec
    ]]
};

-- alternative to bash
dash = {
    url = "http://gondor.apana.org.au/~herbert/dash/files/dash-0.5.12.tar.gz",
    build = "./configure",
    flags = {
        "--bindir=/bin",
        "--mandir=/usr/share/man"
    },
    post = [[
        ln -sf dash ${DESTDIR}/bin/sh
    ]]
};

-- alternative to bison
byacc = {
    url = "https://invisible-island.net/archives/byacc/byacc-20240109.tgz",
    build = "./configure",
};

-- alternative to dinit
sysvinit = {
    url = "https://download.savannah.gnu.org/releases/sysvinit/sysvinit-3.01.tar.xz",
    build = "make",
    flags = {
        "ROOT=${DESTDIR}"
    }
};

-- alternative to gawk
awk = {
    url = "https://github.com/onetrueawk/awk/archive/refs/tags/20220122.tar.gz",
    build = "make"
};

-- alternative to libressl
openssl = {
    url = "https://openssl.org/source/openssl-3.1.2.tar.gz",
    build = "./config",
    flags = {
        "--libdir=/usr/lib64",
        "--openssldir=/etc/ssl",
        "shared",
        "zlib-dynamic"
    },
    post = [[
        rm -f ${DESTDIR}/usr/lib64/{libcrypto.a,libssl.a}
    ]]
};

-- alternative to sudo
opendoas = {
    url = "https://github.com/Duncaen/OpenDoas/releases/download/v6.8.2/opendoas-6.8.2.tar.xz",
    build = "./configure",
    flags = {
        "--disable-static",
        "--with-shadow",
        "--with-timestamp",
        "--without-pam"
    },
    post = [[
        ln -s doas ${DESTDIR}/usr/bin/sudo
    ]]
};

-- needs perl libs
intltool = {
    url = "https://launchpad.net/intltool/trunk/0.51.0/+download/intltool-0.51.0.tar.gz",
    build = "./configure",
    flags = {
        "--libdir=/usr/lib64"
    },
    prepare = [[
        sed -i 's:\\\${:\\\$\\{:' intltool-update.in
    ]]
};

