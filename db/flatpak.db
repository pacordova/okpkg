ostree = {
   url = "https://github.com/ostreedev/ostree/releases/download/v2024.2/libostree-2024.2.tar.xz",
   build = "./configure",
   flags = {
      "--libdir=/usr/lib64",
      "--disable-man",
      "--disable-man-html" 
   }
};

appstream = {
   url = "https://www.freedesktop.org/software/appstream/releases/AppStream-1.0.1.tar.xz",
   build = "meson",
   flags = {
      "-Dsystemd=false",
      "-Ddocs=false",
      "-Dapidocs=false",
      "-Dinstall-docs=false",
      "-Dstemming=false"
   },
   prepare = [[
      mv AppStream*/* . && rm -fr AppStream*
      sed -i '220d' meson.build
   ]]
};

appstream-glib = {
   url = "https://github.com/hughsie/appstream-glib/archive/refs/tags/appstream_glib_0_8_0.tar.gz",
   build = "meson",
   flags = {
      "-Drpm=false",
      "-Dstemmer=false",
      "-Dman=false"
   }
};

libportal = {
   url = "https://github.com/flatpak/libportal/releases/download/0.5/libportal-0.5.tar.xz",
   build = "meson",
   flags = {
      "-Dbackends=gtk3",
      "-Ddocs=false"
   } 
};

portal-gtk = {
   url = "https://github.com/flatpak/xdg-desktop-portal-gtk/releases/download/1.14.0/xdg-desktop-portal-gtk-1.14.0.tar.xz",
   build = "./configure",
};

portal = {
   url = "https://github.com/flatpak/xdg-desktop-portal/releases/download/1.14.6/xdg-desktop-portal-1.14.6.tar.xz",
   build = "./configure",
   flags = {
      "--disable-geoclue",
      "--without-systemd"
   }
};

bwrap = {
   url = "https://github.com/projectatomic/bubblewrap/releases/download/v0.5.0/bubblewrap-0.5.0.tar.xz",
   build = "./configure",
};

flatpak = {
   url = "https://github.com/flatpak/flatpak/releases/download/1.14.5/flatpak-1.14.5.tar.xz",
   build = "./configure",
   flags = {
      "--libdir=/usr/lib64",
      "--localstatedir=/var",
      "--disable-documentation",
      "--without-systemd"
   }    
};
