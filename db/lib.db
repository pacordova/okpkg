      "PREFIX=/usr"
   },
   prepare = [[ sed -i 's#FLAGS\s\+=#FLAGS +=#g' optimised.mk ]],
   post = [[
      mv $destdir/usr/lib $destdir/usr/lib64
      rm $destdir/usr/lib64/libkeccak.a
   ]]
};

