      "--enable-vp9-highbitdepth",
      "--disable-debug",
      "--disable-debug-libs",
      "--disable-docs",
      "--disable-examples",
      "--disable-install-bins",
      "--disable-install-docs",
      "--disable-install-srcs",
      "--disable-static",
      "--disable-tools",
      "--disable-unit-tests",
      "--as=nasm",
   }
};

