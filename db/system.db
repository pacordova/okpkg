kmod = {
   url = "https://kernel.org/pub/linux/utils/kernel/kmod/kmod-32.tar.xz",
   sha3 = "e9435d1b3ce23fb39fa84f3cfbe06fcf772784176e47172fa63959f9ccca30d7",
