   build = "./configure",
   flags = {
      "--bindir=/usr/bin",
      "--mandir=/usr/share/man",
   },
   prepare = [[ sed -i "s/echo/#echo/" src/egrep.sh ]]
};

bash = {
   url = "https://ftp.gnu.org/gnu/bash/bash-5.2.tar.gz",
   sha3 = "01af6b12452665d8202cd50cdc9ca7e6e80d58ba3388d72eb5a0f1c737f8abd7",
   build = "./configure",
   flags = {
      "--libdir=/usr/lib64",
      "--mandir=/usr/share/man",
      "--enable-readline",
      "--with-installed-readline",
      "--without-bash-malloc",
   },
   post = [[
      cd "$destdir/usr"
      ln -sf bash bin/sh
      rm -f bin/bashbug
      rm -f share/man/man1/bashbug.1
   ]]
};

libtool = {
   url = "https://alpha.gnu.org/gnu/libtool/libtool-2.5.0.tar.xz",
