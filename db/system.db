      "--with-grubdir=grub",
      "--enable-device-mapper",
      "--disable-efiemu",
      "--disable-grub-mkfont",
      "--disable-grub-mount",
      "--disable-liblzma",
      "--disable-werror",
      "{C,CPP,CXX,LD}FLAGS="
   },
   prepare = [[ printf "depends bli part_gpt\n" > grub-core/extra_deps.lst ]],
   post = [[
      cd "$destdir/usr/lib64"
      rm -f grub/*/*.module
      rm -f grub/*/*.image
      rm -f grub/*/kernel.exec
      rm -f grub/*/gdb_grub
      rm -f grub/*/gmodule.pl
   ]]
};

cmake = {
   url = "https://cmake.org/files/v3.29/cmake-3.29.6.tar.gz",
   sha3 = "9ce1fbff589d45c3ec21e6884f35a1cad1479a3128af7bf983215b5b9d6ec22e",
   build = "./configure",
   flags = {
      "--mandir=/share/man",
      "--datadir=/share/cmake",
      "--parallel=$(getconf _NPROCESSORS_ONLN)",
      "--system-bzip2",
      "--system-curl",
      "--system-expat",
      "--system-zlib",
      "--no-system-cppdap",
      "--no-system-jsoncpp",
      "--no-system-librhash",
   },
   post = [[
      rm -fr $destdir/usr/share/cmake*/Help
      rm -fr $destdir/usr/share/bash-completion
   ]]
};

