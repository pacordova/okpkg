gcc14 = {
   url = "https://ftp.gnu.org/gnu/gcc/gcc-14.1.0/gcc-14.1.0.tar.xz",
   sha3 = "98ce67e8827f913732dd82b700c18f52ee5acdae8adbae19ba1a8ce5c2978d7c",
   build = "../configure",
   flags = {
      "--libdir=/usr/lib64",
      "--libexecdir=/usr/lib64",
      "--mandir=/usr/share/man",
      "--enable-bootstrap",
      "--enable-checking=release",
      "--enable-clocale=gnu",
      "--enable-__cxa_atexit",
      "--enable-default-pie",
      "--enable-default-ssp",
      "--enable-initfini-array",
      "--enable-languages=c,c++",
      "--enable-link-serialization=1",
      "--enable-lto",
      "--enable-shared",
      "--enable-threads=posix",
      "--disable-fixincludes",
      "--disable-libssp",
      "--disable-libstdcxx-pch",
      "--disable-multilib",
      "--disable-werror",
      "--with-linker-hash-style=gnu",
      "--with-system-zlib",
      "LD=ld",
   },
   post = [[
      find $destdir -name libgtkpeer.a  -exec rm -f '{}' +
      find $destdir -name libgjsmalsa.a -exec rm -f '{}' +
      ln -sf gcc $destdir/usr/bin/cc
      ln -sf gcc $destdir/usr/bin/c99
      mkdir -p $destdir/usr/share/gdb/auto-load/usr/lib64
      cc=$destdir/usr/bin/gcc
      ln -sf ../../lib64/gcc/`$cc -dumpmachine`/`$cc -dumpversion`/liblto_plugin.so \
          $destdir/usr/lib64/bfd-plugins/
      mkdir -p $destdir/usr/lib64/bfd-plugins
      mv $destdir/usr/lib64/*gdb.py $destdir/usr/share/gdb/auto-load/usr/lib64
   ]]
};

