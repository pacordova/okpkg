vim = {
   url = "https://github.com/vim/vim/archive/v9.1.0496/vim-9.1.0496.tar.gz",
   sha3 = "f40dae577d07fad60a8293ae28962eda7d15dfef27aeec810084f5ed51f04a48",
   build = "./configure",
   flags = {
      "--localstatedir=/var/lib/vim",
      "--with-features=huge",
      "--enable-cscope",
      "--enable-multibyte",
      "--disable-canberra",
      "--disable-gpm",
      "--disable-gui",
      "--disable-netbeans",
      "--disable-perlinterp",
      "--disable-pythoninterp",
      "--disable-rubyinterp",
      "--disable-xim",
      "--without-x",
