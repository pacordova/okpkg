      ln -f "$destdir/usr/bin/pigz" "$destdir/usr/bin/unpigz"
      ln -sf pigz   "$destdir/usr/bin/gzip"
      ln -sf unpigz "$destdir/usr/bin/gunzip"
      cp -p  pigz.1 "$destdir/usr/share/man/man1"
   ]]
};

