   sha3 = "d6d65023fb6545d553cc97b222f5001e845872a77cb25240465261a04c3c0892",
   build = "./configure",
   flags = {
      "--sbindir=/usr/bin",
      "--libdir=/usr/lib64",
      "--localstatedir=/var",
      "--sysconfdir=/etc",
      "--mandir=/usr/share/man",
      "--enable-libargon2",
      "--disable-asciidoc",
      "--disable-ssh-token",
      "--disable-static",
