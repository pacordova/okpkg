-- not maintained
libgusb = {
    url = "https://people.freedesktop.org/~hughsient/releases/libgusb-0.3.10.tar.xz",
    build = "meson",
    flags = {
        "-Dprefix=/usr",
        "-Dbuildtype=release",
        "-Dtests=false",
        "-Dvapi=false",
        "-Ddocs=false"
    }
};

