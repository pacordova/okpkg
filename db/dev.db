autoconf = {
   url = "https://ftp.gnu.org/gnu/autoconf/autoconf-2.72.tar.xz",
   sha3 = "58d79b241a66db533747785182df3e49a61c9e5ed7508a002fd5bf033deaf7c8",
   build = "./configure",
   flags = {
      "--mandir=/usr/share/man",
   }
};

automake = {
   url = "https://ftp.gnu.org/gnu/automake/automake-1.16.5.tar.xz",
   sha3 = "e8cd98de6dc46535d983cd02e7ea82bc7565d73bfb36440e731d3199ae88b884",
   build = "./configure",
   flags = {
      "--mandir=/usr/share/man",
   }
};

bc-gh = {
   url = "https://github.com/gavinhoward/bc/releases/download/6.7.5/bc-6.7.5.tar.xz",
   sha3 = "8bbbad6b62e75b0f54bcd0fd5fcba3a41a341ce45afdeb710bcc283619907ab6",
   build = "./configure",
   flags = {
      "--predefined-build-type=GNU",
      "--enable-readline",
      "--disable-generated-tests",
      "--disable-problematic-tests",
   },
   prepare = [[
      sed -e 's/%%CFLAGS%%/-O3/' \
          -e 's/%%HOSTCFLAGS%%/-O3/' \
          -i Makefile.in
   ]]
};

check = {
   url = "https://github.com/libcheck/check/releases/download/0.15.2/check-0.15.2.tar.gz",
   sha3 = "bfb856a68c0ea4d930803f6bd16c1eed38910a231c9e0f0009e69310e35e7a5d",
   build = "./configure",
   flags = {
      "--libdir=/usr/lib64",
      "--localstatedir=/var",
      "--sysconfdir=/etc",
      "--mandir=/usr/share/man",
      "--disable-static"
   }
};

cmake = {
   url = "https://cmake.org/files/v3.29/cmake-3.29.6.tar.gz",
   sha3 = "9ce1fbff589d45c3ec21e6884f35a1cad1479a3128af7bf983215b5b9d6ec22e",
   build = "./configure",
   flags = {
      "--mandir=/share/man",
      "--datadir=/share/cmake",
      "--parallel=$(getconf _NPROCESSORS_ONLN)",
      "--system-libs",
      "--no-system-cppdap",
      "--no-system-curl",
      "--no-system-jsoncpp",
      "--no-system-libarchive",
      "--no-system-librhash",
      "--no-system-libuv",
      "--no-system-nghttp2",
   },
   post = [[
      rm -fr $destdir/usr/share/cmake*/Help
      rm -fr $destdir/usr/share/bash-completion
   ]]
};

gettext = {
   url = "https://ftp.gnu.org/gnu/gettext/gettext-0.22.5.tar.xz",
   sha3 = "410646226a2f971e0789082352d6e270606af924c97305316d3bbd764fa9fbd5",
   build = "./configure",
   flags = {
      "--libdir=/usr/lib64",
      "--mandir=/usr/share/man",
      "--disable-static",
      "--without-git",
   }
};

help2man = {
   url = "https://ftp.gnu.org/gnu/help2man/help2man-1.49.3.tar.xz",
   sha3 = "bc9a32dc38382300d57aa14e87cde7d218841190cb1745e65984a7ddc0bd8cb9",
   build = "./configure",
   flags = {
      "--libdir=/usr/lib64",
      "--localstatedir=/var",
      "--sysconfdir=/etc",
      "--mandir=/usr/share/man",
   }
};

intltool = {
   url = "https://launchpad.net/intltool/trunk/0.51.0/+download/intltool-0.51.0.tar.gz",
   sha3 = "c215547f72957e1727976aeaa7156517fb005a5c8fe0df30e7f546c990ca8d19",
   build = "./configure",
   flags = {
      "--libdir=/usr/lib64",
      "--mandir=/usr/share/man",
   },
   prepare = [[ sed -i 's:\\\${:\\\$\\{:' intltool-update.in ]]
};

libtool = {
   url = "https://alpha.gnu.org/gnu/libtool/libtool-2.5.0.tar.xz",
   sha3 = "6215631f6c42a00b97f90b9881290fede178a0c2294b0b0916b5e792b00a2b87",
   build = "./configure",
   flags = {
      "--libdir=/usr/lib64",
      "--mandir=/usr/share/man",
   },
   post = [[ rm -f $destdir/usr/lib64/libltdl.a ]]
};

meson = {
   url = "https://github.com/mesonbuild/meson/releases/download/1.4.1/meson-1.4.1.tar.gz",
   sha3 = "fa736bf7ea8413d789dc937da6fbfec6ad5fd9e93a04f71c1f0b811e85bb57fd",
   build = "python-build",
};

nasm = {
   url = "https://www.nasm.us/pub/nasm/releasebuilds/2.16.03/nasm-2.16.03.tar.xz",
   sha3 = "3a7634350853231b03bb9fec8f23836a4bc7cfb9f8a48f2317555ac4aec98414",
   build = "./configure",
   flags = { "--libdir=/usr/lib64" }
};

samurai = {
   url = "https://github.com/michaelforney/samurai/releases/download/1.2/samurai-1.2.tar.gz",
   sha3 = "127ea48499f38f1a1c476957453ccca9419c8a4a938925e1361818102307375d",
   build = "make",
   flags = { "PREFIX=/usr" },
   post = [[ ln -sf samu $destdir/usr/bin/ninja ]]
};

texinfo = {
   url = "https://ftp.gnu.org/gnu/texinfo/texinfo-7.1.tar.xz",
   sha3 = "e62a3765829007a33de369d4f0c1b5dfda41b18b73a199bbaf5b2ca4606c2d15",
   build = "./configure",
   flags = {
      "--libdir=/usr/lib64",
      "--sysconfdir=/etc",
      "--mandir=/usr/share/man",
   }
};

which = {
   url = "https://ftp.gnu.org/gnu/which/which-2.21.tar.gz",
   sha3 = "4a008a5fba90aa48ab099a000f60ce1067ef61f05ea0ace5e261066824f67792",
   build = "./configure",
   flags = {
      "--mandir=/usr/share/man",
   }
};
