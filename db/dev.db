   build = "./configure",
   flags = {
      "--libdir=/usr/lib64",
      "--localstatedir=/var",
      "--sysconfdir=/etc",
      "--disable-static",
      "--with-history",
      "--with-legacy",
      "--without-icu",
      "PYTHON=/usr/bin/python3",
   },
   post = [[
      mv $destdir/usr/lib/python*/site-packages/* $destdir/usr/lib64/python*/site-packages
      rm -fr $destdir/usr/lib/python*
   ]]
};

