    "gperf", "libmpc", "libxml2", "libxslt", "linux-headers", "lzip", "m4", 
    "make", "mandoc", "meson", "mpfr", "perl", "pkgconf", "python3", "samurai", 
}

devel = {
    "cmake", "vim", "bc", "json-c", "argon2", "json-c", "popt", "logrotate",
    "efivar", "efibootmgr", "grub2", "dosfstools", "openssh", "libaio", "lvm2",
